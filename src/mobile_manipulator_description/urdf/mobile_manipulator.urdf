<?xml version="1.0" ?>
<!-- =================================================================================== -->
<!-- |    Mobile Manipulator URDF - CORRECTED for CoppeliaSim/V-REP                   | -->
<!-- =================================================================================== -->
<robot name="mobile_robot">

  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="interbotix_black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <!-- Base Footprint (ground reference frame) -->
  <link name="mobile_manipulator/base_footprint"/>

  <!-- FIX #6: Added explicit origin xyz="0 0 0" -->
  <joint name="base_fixed_joint" type="fixed">
    <parent link="mobile_manipulator/base_footprint"/>
    <child link="mobile_manipulator/mobile_base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <!-- Base Link -->
  <link name="mobile_manipulator/mobile_base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.035"/>
      <geometry>
        <mesh filename="meshes/Robotino3_SplitMain.dae" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.035"/>
      <geometry>
        <mesh filename="meshes/Robotino3_SplitMain.dae" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.002288 0.045646 0.074145"/>
      <mass value="20.0"/>
      <inertia ixx="0.258839226" ixy="0.002668446" ixz="-0.005336891"
               iyy="0.394929953" iyz="0.005336891" izz="0.426951301"/>
    </inertial>
  </link>

  <!-- FIX #1 + #5: wheel0_joint changed revolute -> continuous, collision sphere -> cylinder -->
  <joint name="wheel0_joint" type="continuous">
    <parent link="mobile_manipulator/mobile_base_link"/>
    <child link="mobile_manipulator/wheel0_link"/>
    <origin rpy="0 0 0" xyz="-0.0001 0.1825 0.059154"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="10.0"/>
  </joint>

  <link name="mobile_manipulator/wheel0_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Robotino3_SplitWheel.dae" scale="0.01 0.01 0.01"/>
      </geometry>
    </visual>
    <collision>
      <!-- Cylinder better represents wheel contact dynamics than sphere -->
      <origin rpy="1.5707963267948966 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.052"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.000091 -0.000123 -0.000182"/>
      <mass value="0.315"/>
      <inertia ixx="0.000353139" ixy="0.0" ixz="0.0"
               iyy="0.000706278" iyz="0.0" izz="0.000353139"/>
    </inertial>
  </link>

  <!-- FIX #1 + #5: wheel1_joint changed revolute -> continuous, collision sphere -> cylinder -->
  <joint name="wheel1_joint" type="continuous">
    <parent link="mobile_manipulator/mobile_base_link"/>
    <child link="mobile_manipulator/wheel1_link"/>
    <origin rpy="0 0 2.094395102393195" xyz="-0.157067 -0.090625 0.059154"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="10.0"/>
  </joint>

  <link name="mobile_manipulator/wheel1_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Robotino3_SplitWheel.dae" scale="0.01 0.01 0.01"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.052"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.000091 -0.000123 -0.000182"/>
      <mass value="0.315"/>
      <inertia ixx="0.000353139" ixy="0.0" ixz="0.0"
               iyy="0.000706278" iyz="0.0" izz="0.000353139"/>
    </inertial>
  </link>

  <!-- FIX #1 + #5: wheel2_joint changed revolute -> continuous, collision sphere -> cylinder -->
  <joint name="wheel2_joint" type="continuous">
    <parent link="mobile_manipulator/mobile_base_link"/>
    <child link="mobile_manipulator/wheel2_link"/>
    <origin rpy="0 0 -2.094395102393195" xyz="0.156867 -0.090625 0.059154"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="10.0"/>
  </joint>

  <link name="mobile_manipulator/wheel2_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Robotino3_SplitWheel.dae" scale="0.01 0.01 0.01"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.052"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.000091 -0.000123 -0.000182"/>
      <mass value="0.315"/>
      <inertia ixx="0.000353139" ixy="0.0" ixz="0.0"
               iyy="0.000706278" iyz="0.0" izz="0.000353139"/>
    </inertial>
  </link>

  <!-- IMU Joint -->
  <joint name="imu_joint" type="fixed">
    <parent link="mobile_manipulator/mobile_base_link"/>
    <child link="mobile_manipulator/imu_link"/>
    <origin rpy="0 0 0" xyz="0.0 -0.06 0.10"/>
  </joint>

  <!-- FIX #3: IMU link inertia reduced to near-zero (sensor/dummy link) -->
  <link name="mobile_manipulator/imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-9" ixy="0" ixz="0"
               iyy="1e-9" iyz="0"
               izz="1e-9"/>
    </inertial>
  </link>

  <!-- Platform Joint -->
  <joint name="platform_joint" type="fixed">
    <parent link="mobile_manipulator/mobile_base_link"/>
    <child link="mobile_manipulator/platform_link"/>
    <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.32"/>
  </joint>

  <!-- FIX #3: platform_link inertia reduced (structural mount, not dynamic element) -->
  <link name="mobile_manipulator/platform_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-4" ixy="0" ixz="0"
               iyy="1e-4" iyz="0"
               izz="1e-4"/>
    </inertial>
    <visual>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 -0.02"/>
      <geometry>
        <cylinder length="0.04" radius="0.2"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 -0.02"/>
      <geometry>
        <cylinder length="0.04" radius="0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- FIX #7: Renamed "fixed" -> "platform_to_base_joint" to avoid name conflicts -->
  <joint name="platform_to_base_joint" type="fixed">
    <parent link="mobile_manipulator/platform_link"/>
    <child link="mobile_manipulator/base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <!-- Arm Base Link -->
  <link name="mobile_manipulator/base_link">
    <visual>
      <origin rpy="0 0 1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-1-Base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="interbotix_black"/>
    </visual>
    <collision>
      <origin rpy="0 0 1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-1-Base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 1.5707963267948966" xyz="-0.0534774000 -0.0005625750 0.0205961000"/>
      <mass value="0.969034"/>
      <inertia ixx="0.0060240000" ixy="0.0000471300" ixz="0.0000038510"
               iyy="0.0017000000" iyz="-0.0000841500" izz="0.0071620000"/>
    </inertial>
  </link>

  <!-- Waist Joint -->
  <joint name="waist_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="10.6" lower="-3.141592653589793" upper="3.141592653589793" velocity="3.1"/>
    <origin rpy="0 0 0" xyz="0 0 0.0787"/>
    <parent link="mobile_manipulator/base_link"/>
    <child link="mobile_manipulator/shoulder_link"/>
  </joint>

  <!-- Shoulder Link -->
  <link name="mobile_manipulator/shoulder_link">
    <visual>
      <origin rpy="0 0 1.5707963267948966" xyz="0 0 -0.003"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-2-Shoulder.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="interbotix_black"/>
    </visual>
    <collision>
      <origin rpy="0 0 1.5707963267948966" xyz="0 0 -0.003"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-2-Shoulder.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 1.5707963267948966" xyz="0.0002592330 -0.0000033552 0.0116129000"/>
      <mass value="0.798614"/>
      <inertia ixx="0.0009388000" ixy="-0.0000000010" ixz="-0.0000000191"
               iyy="0.0011380000" iyz="0.0000059568" izz="0.0012010000"/>
    </inertial>
  </link>

  <!-- Shoulder Joint -->
  <joint name="shoulder_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="21.2" lower="-1.8500490071139892" upper="1.7627825445142729" velocity="3.1"/>
    <origin rpy="-1.5707963267948966 0 0" xyz="0 0 0.04805"/>
    <parent link="mobile_manipulator/shoulder_link"/>
    <child link="mobile_manipulator/upper_arm_link"/>
  </joint>

  <!-- Upper Arm Link -->
  <link name="mobile_manipulator/upper_arm_link">
    <visual>
      <origin rpy="1.5707963267948966 -1.5707963267948966 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-3-UA.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="interbotix_black"/>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 -1.5707963267948966 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-3-UA.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="1.5707963267948966 -1.5707963267948966 0" xyz="0.0206949000 -0.2264590000 0.0000000004"/>
      <mass value="0.792592"/>
      <inertia ixx="0.0089250000" ixy="0.0000000000" ixz="0.0000000000"
               iyy="0.0089370000" iyz="0.0012010000" izz="0.0009357000"/>
    </inertial>
  </link>

  <!-- Elbow Joint -->
  <joint name="elbow_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="21.2" lower="-1.6057029118347832" upper="1.7627825445142729" velocity="3.1"/>
    <origin rpy="3.141592653589793 0 -1.5707963267948966" xyz="0.05955 -0.3 0.0"/>
    <parent link="mobile_manipulator/upper_arm_link"/>
    <child link="mobile_manipulator/upper_forearm_link"/>
  </joint>

  <!-- Upper Forearm Link -->
  <link name="mobile_manipulator/upper_forearm_link">
    <visual>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-4-UF.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="interbotix_black"/>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-4-UF.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 -0.105723 0"/>
      <mass value="0.322228"/>
      <inertia ixx="0.0001524000" ixy="-0.0000188300" ixz="-0.0000084064"
               iyy="0.0013420000" iyz="0.0000012564" izz="0.0014410000"/>
    </inertial>
  </link>

  <!-- Upper Forearm Joint -->
  <joint name="upper_forearm_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="10.6" lower="-3.141592653589793" upper="3.141592653589793" velocity="3.1"/>
    <origin rpy="1.5707963267948966 0 0" xyz="0 -0.2 0"/>
    <parent link="mobile_manipulator/upper_forearm_link"/>
    <child link="mobile_manipulator/lower_forearm_link"/>
  </joint>

  <!-- Lower Forearm Link -->
  <link name="mobile_manipulator/lower_forearm_link">
    <visual>
      <origin rpy="0 -1.5707963267948966 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-5-LF.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="interbotix_black"/>
    </visual>
    <collision>
      <origin rpy="0 -1.5707963267948966 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-5-LF.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 -1.5707963267948966 0" xyz="0 -0.0068046200 0.0513477000"/>
      <mass value="0.414823"/>
      <inertia ixx="0.0001753000" ixy="-0.0000852800" ixz="0"
               iyy="0.0005269000" iyz="0" izz="0.0005911000"/>
    </inertial>
  </link>

  <!-- Lower Forearm Joint -->
  <joint name="lower_forearm_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="10.6" lower="-2.2689280275926285" upper="1.8675022996339325" velocity="3.1"/>
    <origin rpy="-1.5707963267948966 0 0" xyz="0 0 0.1"/>
    <parent link="mobile_manipulator/lower_forearm_link"/>
    <child link="mobile_manipulator/wrist_link"/>
  </joint>

  <!-- Wrist Link -->
  <link name="mobile_manipulator/wrist_link">
    <visual>
      <origin rpy="0 1.5707963267948966 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-6-Wrist.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="interbotix_black"/>
    </visual>
    <collision>
      <origin rpy="0 1.5707963267948966 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-6-Wrist.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 1.5707963267948966 0" xyz="0.0105650000 -0.0467430000 0.0000076652"/>
      <mass value="0.115395"/>
      <inertia ixx="0.0000463100" ixy="0.0000000195" ixz="0.0000000023"
               iyy="0.0000451400" iyz="0.0000042002" izz="0.0000527000"/>
    </inertial>
  </link>

  <!-- Wrist Joint -->
  <joint name="wrist_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="4.1" lower="-3.141592653589793" upper="3.141592653589793" velocity="3.1"/>
    <origin rpy="1.5707963267948966 3.141592653589793 0" xyz="0 -0.069744 0"/>
    <parent link="mobile_manipulator/wrist_link"/>
    <child link="mobile_manipulator/base_gripper_link"/>
  </joint>

  <!-- FIX #2: base_gripper_link collision origin corrected to match visual xyz -->
  <link name="mobile_manipulator/base_gripper_link">
    <visual>
      <origin rpy="1.5707963267948966 3.141592653589793 -1.5707963267948966" xyz="0 0 -0.02"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-7-Gripper.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="interbotix_black"/>
    </visual>
    <collision>
      <!-- FIX: was xyz="-0.02 0 0", corrected to match visual origin -->
      <origin rpy="1.5707963267948966 3.141592653589793 -1.5707963267948966" xyz="0 0 -0.02"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-7-Gripper.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="1.5707963267948966 3.141592653589793 -1.5707963267948966" xyz="-0.0115230000 0.0000000000 0.0230010000"/>
      <mass value="0.097666"/>
      <inertia ixx="0.0000326800" ixy="0.0000000000" ixz="0.0000000000"
               iyy="0.0000243600" iyz="0.0000002785" izz="0.0000211900"/>
    </inertial>
  </link>

  <!-- TCP Joint -->
  <joint name="tcp_joint" type="fixed">
    <origin rpy="0 -1.5707963267948966 0" xyz="0.0 0 0.042825"/>
    <parent link="mobile_manipulator/base_gripper_link"/>
    <child link="mobile_manipulator/end_effector_link"/>
  </joint>

  <!-- FIX #3: end_effector_link inertia reduced to near-zero (virtual/TCP frame) -->
  <link name="mobile_manipulator/end_effector_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-9" ixy="0" ixz="0"
               iyy="1e-9" iyz="0"
               izz="1e-9"/>
    </inertial>
  </link>

  <!-- FIX #4: gripper_joint is fixed - removed orphan <axis> and <limit> tags -->
  <joint name="gripper_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.005675 0 0"/>
    <parent link="mobile_manipulator/end_effector_link"/>
    <child link="mobile_manipulator/gripper_prop_link"/>
  </joint>

  <!-- Gripper Prop Link -->
  <link name="mobile_manipulator/gripper_prop_link">
    <visual>
      <origin rpy="0 0 1.5707963267948966" xyz="-0.0685 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-8-Gripper-Prop.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="interbotix_black"/>
    </visual>
    <collision>
      <origin rpy="0 0 1.5707963267948966" xyz="-0.0685 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-8-Gripper-Prop.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 1.5707963267948966" xyz="0.0023780000 0.0000000285 0.0000000000"/>
      <mass value="0.008009"/>
      <inertia ixx="0.0000020386" ixy="0.0000000000" ixz="0.0000006559"
               iyy="0.0000042979" iyz="0.0000000000" izz="0.0000023796"/>
    </inertial>
  </link>

  <!-- Gripper Bar Joint -->
  <joint name="gripper_bar_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="mobile_manipulator/end_effector_link"/>
    <child link="mobile_manipulator/gripper_bar_link"/>
  </joint>

  <!-- Gripper Bar Link -->
  <link name="mobile_manipulator/gripper_bar_link">
    <visual>
      <origin rpy="0 0 1.5707963267948966" xyz="-0.063 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-9-Gripper-Bar.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="interbotix_black"/>
    </visual>
    <collision>
      <origin rpy="0 0 1.5707963267948966" xyz="-0.063 0 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-9-Gripper-Bar.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 1.5707963267948966" xyz="0.0067940000 -0.0000004272 -0.0007760000"/>
      <mass value="0.150986"/>
      <inertia ixx="0.0000789500" ixy="-0.0000000012" ixz="0.0000001341"
               iyy="0.0003283000" iyz="0.0000017465" izz="0.0003095000"/>
    </inertial>
  </link>

  <!-- TCP Bar Joint -->
  <joint name="tcp_bar" type="fixed">
    <origin rpy="0 0 0" xyz="0.025875 0 0"/>
    <parent link="mobile_manipulator/gripper_bar_link"/>
    <child link="mobile_manipulator/tcp_bar_link"/>
  </joint>

  <!-- FIX #3: tcp_bar_link inertia reduced to near-zero (virtual frame) -->
  <link name="mobile_manipulator/tcp_bar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-9" ixy="0.0" ixz="0.0"
               iyy="1e-9" iyz="0.0"
               izz="1e-9"/>
    </inertial>
  </link>

  <!-- Left Finger Joint -->
  <joint name="left_finger_joint" type="prismatic">
    <axis xyz="0 1 0"/>
    <limit effort="10" lower="-0.018" upper="0.018" velocity="1"/>
    <origin rpy="0 0 0" xyz="0 0.039 0"/>
    <parent link="mobile_manipulator/tcp_bar_link"/>
    <child link="mobile_manipulator/left_finger_link"/>
  </joint>

  <!-- Left Finger Link -->
  <link name="mobile_manipulator/left_finger_link">
    <visual>
      <origin rpy="1.5707963267948966 -3.141592653589793 1.5707963267948966" xyz="-0.0404 -0.0575 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-10-Finger.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="interbotix_black"/>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 -3.141592653589793 1.5707963267948966" xyz="-0.0404 -0.0575 0"/>
      <geometry>
        <mesh filename="meshes/VXSA-300-M-10-Finger.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="3.141592653589793 3.141592653589793 1.5707963267948966" xyz="0.0173440000 -0.0060692000 0.0000000000"/>
      <mass value="0.034796"/>
      <inertia ixx="0.0000243300" ixy="-0.0000024004" ixz="0.0000000000"
